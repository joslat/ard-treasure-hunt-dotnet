# Build output
[Bb]in/
[Oo]bj/
.vs/
*.user

# NuGet
*.nupkg
packages/

# Node (vendored TS servers under servers/* also carry their own .gitignore)
node_modules/
dist/

# Aspire / azd — azd generates compute infra into infra/ and src/Ard.AppHost/infra/ on `azd up`;
# keep only our hand-authored infra/dns.bicep.
.azure/
src/Ard.AppHost/infra/
**/aspire-manifest.json
/infra/*
!/infra/dns.bicep

# Committed showcase image lives in artifacts/run/ — keep only award.png there
/artifacts/run/*
!/artifacts/run/award.png

# Default walker / award output (hunt-report.json + award.html, created by `dotnet run`)
ard-output/
